{
  "name": "saltor-system",
  "version": "1.0.43",
  "description": "Sistema de facturacion, caja e inventario para multi-sucursal.",
  "author": "Saltor System",
  "main": "electron/main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "prepare": "node scripts/install-git-hooks.js",
    "build:icon": "node scripts/generate-icons.js",
    "version:sync": "node scripts/sync-version.js",
    "version:bump:commit": "node scripts/bump-version.js",
    "version:desktop": "node scripts/prepare-desktop-version.js",
    "desktop": "yarn build --configuration production --base-href ./ && electron electron/main.js",
    "desktop:dev": "cross-env ELECTRON_START_URL=http://localhost:4200 electron electron/main.js",
    "desktop:pack": "yarn version:desktop && yarn build:icon && yarn build --configuration production --base-href ./ && electron-builder --publish never",
    "desktop:pack:win": "yarn version:desktop && yarn build:icon && yarn build --configuration production --base-href ./ && electron-builder --win nsis --x64 --publish never",
    "desktop:pack:win:publish": "yarn version:desktop && yarn build:icon && yarn build --configuration production --base-href ./ && electron-builder --win nsis --x64 --publish always",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "dev": "cross-env PORT=3390 npx kill-port 3390 && nodemon src/index.js",
    "deploy:ghp": "npm run build && gh-pages -d dist/saltor-system"
  },
  "build": {
    "appId": "com.saltorsystem.desktop",
    "productName": "Saltor System",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "SalvadorTorre",
        "repo": "SaltorSystem",
        "releaseType": "release"
      }
    ],
    "files": [
      "dist/saltor-system/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "artifactName": "SaltorSystem-Desktop-Setup-${version}.${ext}",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    }
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^16.2.0",
    "@angular/common": "^16.2.0",
    "@angular/compiler": "^16.2.0",
    "@angular/core": "^16.2.0",
    "@angular/forms": "^16.2.0",
    "@angular/platform-browser": "^16.2.0",
    "@angular/platform-browser-dynamic": "^16.2.0",
    "@angular/router": "^16.2.0",
    "@angular/service-worker": "^16.2.12",
    "@popperjs/core": "^2.11.8",
    "@supabase/supabase-js": "^2.103.3",
    "bootstrap": "^5.3.7",
    "bootstrap-icons": "^1.11.3",
    "electron-updater": "^6.8.3",
    "html2canvas": "^1.4.1",
    "html2pdf.js": "^0.10.3",
    "inputmask": "^5.0.9",
    "jquery": "^3.7.1",
    "jsbarcode": "^3.12.1",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "ngx-mask": "^18.0.0",
    "pdf-to-printer": "^5.8.0",
    "pdfmake": "^0.2.20",
    "qrcode": "^1.5.4",
    "rxjs": "~7.8.0",
    "sweetalert2": "^11.6.13",
    "tslib": "^2.3.0",
    "zone.js": "~0.13.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^16.0.6",
    "@angular/cli": "^16.2.14",
    "@angular/compiler-cli": "^16.2.0",
    "@types/jasmine": "~4.3.0",
    "@types/node": "^18.19.3",
    "@types/qrcode": "^1.5.6",
    "cross-env": "^10.1.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "gh-pages": "^6.3.0",
    "jasmine-core": "~4.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "kill-port": "^2.0.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "~5.1.3"
  },
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SalvadorTorre/SaltorSystem.git"
  },
  "keywords": [],
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/SalvadorTorre/SaltorSystem/issues"
  },
  "homepage": "https://github.com/SalvadorTorre/SaltorSystem#readme"
}
